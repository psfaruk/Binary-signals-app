# Binary-signals-app — Environment Variables Template
#
# Copy this file to `.env` and fill in your Quotex credentials:
#   cp .env.example .env
#
# On Railway, set these directly in the Railway Variables dashboard —
# do NOT create a .env file on Railway (the filesystem is read-only).

# ─── Quotex Credentials ────────────────────────────────────────────────
# Get your token from Quotex's browser devtools (Network → WS frames →
# "ssid" message). The token starts with `{"token":"...` and is a long
# JSON string. Either QX_TOKEN (preferred) or QX_EMAIL+QX_PASSWORD works.
QX_TOKEN=
QX_EMAIL=
QX_PASSWORD=

# ─── Backend Selection ────────────────────────────────────────────────
# QX_USE_RAW_WS=0 (DEFAULT): vendored pyquotex with Firefox TLS cipher
#                             suite → bypasses Cloudflare without
#                             Playwright/curl_cffi.
# QX_USE_RAW_WS=1:           raw WebSocket backend (quotex_ws.py)
#                             → lighter but Cloudflare blocks login on
#                               datacenter IPs (e.g. Railway).
QX_USE_RAW_WS=0

# ─── Simulation Mode ──────────────────────────────────────────────────
# USE_SIM=1 forces the simulated feed even when Quotex credentials are
# present. Useful for development / demos without hitting the real broker.
USE_SIM=1

# ─── Payout Floors ────────────────────────────────────────────────────
# Pairs below this payout % are blocked from streaming entirely.
# Real-market pairs have lower broker margins → lower payouts.
# OTC pairs have higher headline payouts.
QX_PAYOUT_FLOOR_REAL=70
QX_PAYOUT_FLOOR_OTC=85

# ─── Signal Tuning ────────────────────────────────────────────────────
# Withhold prediction for N seconds after candle open so opening ticks
# can confirm gap direction.
SIGNAL_DELAY_SEC=3.0

# LIVE re-eval: re-run prediction mid-candle when fresh ticks arrive.
ENABLE_LIVE_REEVAL=1

# Strength gate: demote signals whose running-candle confirmation
# opposes the prediction direction.
ENABLE_STRENGTH_GATE=1

# ─── Per-Pair DB Adaptation Tuning ────────────────────────────────────
# Min graded samples before DB adaptation kicks in (below this, static
# config is used unchanged).
ADAPT_MIN_SAMPLES=20
# Static-config prior weight (0.7) vs DB-learned weight (0.3).
ADAPT_PRIOR=0.7
# Cap on per-module adaptation magnitude (±30%).
ADAPT_CAP=0.30
# In-memory cache TTL for per-pair DB lookups (seconds).
ADAPT_CACHE_TTL=60

# ─── Server ───────────────────────────────────────────────────────────
# Port to bind to. Railway sets $PORT automatically — do NOT set this
# in Railway Variables.
PORT=8000

# Auto-open browser on startup (local dev only). Set to 0 on Railway.
AUTO_OPEN_BROWSER=1

# ─── Database ─────────────────────────────────────────────────────────
# Path to signals.db. Defaults to ./signals.db. On Railway, set this to
# a persistent volume mount path (e.g. /data/signals.db).
DB_PATH=signals.db
