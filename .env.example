# ── Quotex Account Credentials ───────────────────────────────────────────────
# আপনার Quotex অ্যাকাউন্টের email + password দিন। qx_login.py এটা দিয়ে
# Cloudflare-safe browser-impersonated login করে ssid আনবে।
QX_EMAIL=your_email@example.com
QX_PASSWORD=your_password

# ── Session Token (optional — fast path) ────────────────────────────────────
# যদি আগে থেকেই একটি কাজ করা ssid থাকে (browser থেকে কপি করা), সেটা এখানে দিন।
# তাহলে email/password login step skip হবে এবং সরাসরি WebSocket connect হবে।
# ব্রাউজারে Quotex-এ login করুন → DevTools → Application → Cookies → "session" কপি করুন।
# QX_TOKEN=abc123def456...

# ── Backend Selection ────────────────────────────────────────────────────────
# QX_USE_RAW_WS=1 (DEFAULT, recommended) → raw Socket.IO v3 WebSocket client
#                                          (bypasses pyquotex, Cloudflare-safe)
# QX_USE_RAW_WS=0                        → legacy pyquotex backend
QX_USE_RAW_WS=1

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8000

# ── Optional Tuning (defaults are fine) ─────────────────────────────────────
# MICRO_RECALC_EVERY=3      # recompute microstructure every N ticks
# SKIP_REDUNDANT_BROADCAST=1 # skip identical-candle broadcasts
# SIGNAL_DELAY_SEC=3.0      # delay prediction broadcast by N seconds
# QX_PAYOUT_FLOOR=81        # minimum payout % for tradeable pairs
